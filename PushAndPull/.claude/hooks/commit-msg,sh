#!/bin/bash

COMMIT_MSG=$(cat "$1")

# trim leading/trailing whitespace
COMMIT_MSG=$(echo "$COMMIT_MSG" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

# allowed types 
TYPES="feat|fix|update|refactor|test|chore"

# pattern: type: message
PATTERN="^($TYPES): .+"

# 1. format check
if [[ ! "$COMMIT_MSG" =~ $PATTERN ]]; then
    echo "[Hook] ✗ Invalid commit message format"
    echo ""
    echo "Expected:"
    echo "  {type}: {description}"
    echo ""
    echo "Allowed types:"
    echo "  feat     — new feature"
    echo "  fix      — bug fix"
    echo "  update   — modification"
    echo "  refactor — code refactoring"
    echo "  test     — test related"
    echo "  chore    — build/config"
    echo ""
    echo "Examples:"
    echo "  feat: 로그인 로직 추가"
    echo "  fix: 세션 DI 누락 수정"
    echo "  test: 유저 서비스 테스트 추가"
    exit 1
fi

if [[ "$COMMIT_MSG" =~ [\.\!]$ ]]; then
    echo "[Hook] ✗ Do not end the message with punctuation"
    exit 1
fi

if [[ "$COMMIT_MSG" == *$'\n'* ]]; then
    echo "[Hook] ✗ Commit body is not allowed"
    exit 1
fi

LENGTH=${#COMMIT_MSG}

if (( LENGTH < 10 )); then
    echo "[Hook] ✗ Commit message too short (min: 10 chars)"
    exit 1
fi

if (( LENGTH > 72 )); then
    echo "[Hook] ✗ Commit message too long (max: 72 chars)"
    exit 1
fi

echo "[Hook] ✓ Commit message format valid"