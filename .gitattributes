# Normalize line endings to LF in the repository
* text=auto eol=lf

# Explicitly declare text files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.dockerfile text eol=lf
*.dockerignore text eol=lf
*.gitignore text eol=lf

# Binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
